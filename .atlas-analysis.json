  "keyFeatures": [
    "AI-powered CLI coding agent with React/Ink terminal UI",
    "Model Context Protocol (MCP) server management and integration",
    "Extensible plugin and skills system for custom commands",
    "Multi-agent coordination with async task management",
    "Rich tool suite: file editing, bash execution, web search, notebooks",
    "Remote session support for mobile and web clients",
    "Feature flag system for build-time code elimination",
    "Integrated memory system for project and session context",
    "OAuth and API key authentication with multiple providers"
  ],
  "publicApiSurface": [
    "claude (main CLI entrypoint)",
    "/mcp [enable|disable <server-name>] — manage MCP servers",
    "/login — authenticate with Anthropic or console API key",
    "/logout — remove stored credentials",
    "/review — AI code review for current changes",
    "/config — view and modify configuration",
    "/memory — manage project and user memory files",
    "/permissions — manage tool permission settings",
    "/skills — list and manage available skills",
    "/session — manage and share sessions",
    "/tasks — view and manage async background tasks",
    "/plan — toggle plan mode for multi-step coding",
    "/hooks — configure lifecycle event hooks",
    "/model — switch the active Claude model",
    "/compact — compact conversation context",
    "BashTool — execute shell commands",
    "FileEditTool — edit files with surgical precision",
    "FileReadTool — read file contents",
    "FileWriteTool — write new files",
    "GlobTool — find files by pattern",
    "GrepTool — search file contents",
    "WebFetchTool — fetch URLs",
    "WebSearchTool — web search",
    "AgentTool — spawn sub-agents",
    "MCPTool — invoke MCP server tools",
    "TodoWriteTool — manage task lists"
  ]
